# Core app settings
APP_HOMEPAGE_URL=https://forms.example.com
SESSION_KEY=replace-with-a-long-random-secret
FORM_ENCRYPTION_KEY=replace-with-another-long-random-secret

# Published host port for HeyForm
HEYFORM_HOST_PORT=9513

# Optional images if you want to pin or override upstream defaults
HEYFORM_IMAGE=heyform/community-edition:latest
MONGO_IMAGE=percona/percona-server-mongodb:4.4
KEYDB_IMAGE=eqalpha/keydb:latest

# Optional registration lock-down
APP_DISABLE_REGISTRATION=false

# Mongo connection used by HeyForm
MONGO_URI=mongodb://mongo:27017/heyform

# Optional KeyDB overrides
REDIS_HOST=keydb
REDIS_PORT=6379
